# Startup-Auditor Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# Wafer Pass LLM API Key (required)
# Get your key from https://docs.wafer.ai/wafer-pass
WAFER_PASS_API_KEY=your_key_here

# Playwright Browsers Path (optional)
# Default: uses system-wide browser installation
PLAYWRIGHT_BROWSERS_PATH=/path/to/browsers

# Log Level (optional)
# Options: DEBUG, INFO, WARNING, ERROR
# Default: INFO
LOG_LEVEL=INFO
